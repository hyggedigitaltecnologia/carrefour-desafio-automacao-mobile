{
  "name": "carrefour-mobile-automation",
  "version": "1.0.0",
  "description": "Desafio de automação de testes mobile - Carrefour Banco",
  "author": "Jhonattan Gomes",
  "license": "ISC",
  "scripts": {
    "android": "wdio config/wdio.android.conf.js",
    "android:smoke": "wdio config/wdio.android.conf.js --mochaOpts.grep '@smoke'",
    "android:regression": "wdio config/wdio.android.conf.js --mochaOpts.grep '@regression'",
    "android:e2e": "wdio config/wdio.android.conf.js --mochaOpts.grep '@e2e'",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open",
    "clean": "rm -rf allure-results allure-report screenshots/*.png",
    "lint": "eslint test/**/*.js config/**/*.js"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/junit-reporter": "^9.27.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "appium": "^2.0.0",
    "appium-uiautomator2-driver": "^3.0.0",
    "chai": "^4.3.10",
    "csv-parse": "^5.5.0",
    "eslint": "^8.50.0"
  }
}
